---
import { getCollection, render } from 'astro:content';
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import Tag from "@/components/Tag.astro";
import SupplierMeta from "@/components/SupplierMeta.astro";
import { SITE } from "@/config";
import { slugifyStr } from "@/utils/slugify";

export async function getStaticPaths() {
  const suppliers = await getCollection('supplier', ({ data }) => !data.draft);
  return suppliers.map(supplier => ({ params: { slug: supplier.slug }, props: { supplier } }));
}

const { supplier } = Astro.props;
const { Content } = await render(supplier);
---

<Layout title={`${supplier.data.title} | ${SITE.title}`} description={supplier.data.description}>
  <Header />
  <div class="app-layout pb-4">
    {SITE.showBackButton && <BackButton />}
    <main id="main-content">
      <h1 class="text-2xl font-semibold sm:text-3xl">{supplier.data.title}</h1>
      <ul class="my-3 flex flex-wrap gap-2">
        {supplier.data.tags.map(tag => (
          <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
        ))}
      </ul>
      <SupplierMeta
        title={supplier.data.title}
        scales={supplier.data.scales}
        website_url={supplier.data.website_url}
      />
      <article class="prose mt-6 max-w-none dark:prose-invert">
        <Content />
      </article>
    </main>
  </div>
  <Footer />
</Layout>
