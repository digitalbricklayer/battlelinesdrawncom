---
import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts, getAllTags } from '../utils/collections';

const posts = await getPublishedPosts();
const allTags = await getAllTags();

const featured = posts.filter(p => p.data.featured);
const recent = posts.filter(p => !p.data.featured);
---

<Base title="Home" description="One man's journey into tabletop wargaming and beyond.">
  <div class="wrap">
    <div class="post_content">
      {featured.length > 0 && (
        <section class="featured-section">
          <h2>Featured</h2>
          <ul class="post-list">
            {featured.map(p => (
              <PostCard
                title={p.data.title}
                href={`/post/${p.slug}/`}
                date={p.data.date}
                description={p.data.description}
                thumbnail={p.data.thumbnail}
                tags={p.data.tags}
              />
            ))}
          </ul>
        </section>
      )}

      <section>
        <h2 class="page-header" style="border-bottom: 2px solid var(--color-border); padding-bottom: 0.5rem; margin-bottom: 1rem;">Recent Posts</h2>
        <ul class="post-list">
          {recent.slice(0, 10).map(p => (
            <PostCard
              title={p.data.title}
              href={`/post/${p.slug}/`}
              date={p.data.date}
              description={p.data.description}
              thumbnail={p.data.thumbnail}
              tags={p.data.tags}
            />
          ))}
        </ul>
      </section>
    </div>
    <Sidebar recentPosts={posts} allTags={allTags} />
  </div>
</Base>
