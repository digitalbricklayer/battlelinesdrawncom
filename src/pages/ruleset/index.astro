---
import { getCollection } from 'astro:content';
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";

const rulesets = await getCollection('ruleset', ({ data }) => !data.draft);
rulesets.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={`Rulesets | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Rulesets" pageDesc="All wargaming rules currently of interest or actively in use on the Battle Lines Drawn blog.">
    <ul>
      {rulesets.map(ruleset => (
        <li class="my-6">
          <a
            href={`/ruleset/${ruleset.slug}/`}
            class="inline-block text-lg font-medium text-accent decoration-dashed underline-offset-4 hover:underline"
          >
            <h2>{ruleset.data.title}</h2>
          </a>
          {ruleset.data.description && (
            <p class="mt-1 text-foreground/80">{ruleset.data.description}</p>
          )}
          {ruleset.data.tags.length > 0 && (
            <ul class="mt-2 flex flex-wrap gap-2">
              {ruleset.data.tags.map(tag => (
                <li>
                  <a
                    href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}/`}
                    class="text-sm text-accent hover:underline"
                  >
                    #{tag}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </Main>
  <Footer />
</Layout>
