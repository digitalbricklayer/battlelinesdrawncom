---
import { slugify } from '../utils/slugify';

interface Props {
  title: string;
  href: string;
  date: Date;
  description?: string;
  thumbnail?: string;
  tags?: string[];
}

const { title, href, date, description, thumbnail, tags = [] } = Astro.props;

const dateStr = date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---

<li class="post-card">
  {thumbnail && (
    <div class="post-card__thumb">
      <img src={thumbnail} alt={title} loading="lazy" />
    </div>
  )}
  <div class="post-card__body">
    <h2 class="post-card__title"><a href={href}>{title}</a></h2>
    <div class="post-card__meta">{dateStr}</div>
    {description && <p class="post-card__desc">{description}</p>}
    {tags.length > 0 && (
      <div style="margin-top: 0.5rem; display: flex; flex-wrap: wrap; gap: 0.3rem;">
        {tags.map(tag => <a href={`/tags/${slugify(tag)}/`} class="tag-chip">{tag}</a>)}
      </div>
    )}
  </div>
</li>
