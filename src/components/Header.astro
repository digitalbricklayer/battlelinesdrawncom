---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Posts', href: '/post/' },
  { label: 'Projects', href: '/project/' },
  { label: 'Armies', href: '/army/' },
  { label: 'Rules', href: '/ruleset/' },
  { label: 'Suppliers', href: '/supplier/' },
  { label: 'About', href: '/about-us/' },
];

const current = Astro.url.pathname;
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/logos/logo-150x150.jpg" alt="Battle Lines Drawn" />
      Battle Lines Drawn
    </a>
    <ul class="nav-links">
      {navLinks.map(link => (
        <li>
          <a href={link.href} aria-current={current === link.href ? 'page' : undefined}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="nav-search">
      <a href="/search/">Search</a>
    </div>
  </div>
</nav>
