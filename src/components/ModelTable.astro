---
import { slugifyStr } from "@/utils/slugify";

interface Model {
  name: string;
  qty: number | string;
  sku?: string | null;
  supplier?: string | null;
}

interface Props {
  models: Model[];
}

const { models } = Astro.props;
---

{models.length > 0 && (
  <div class="my-4 overflow-x-auto">
    <h2 class="mb-2 font-semibold">Army Contents</h2>
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr class="border-b-2 border-border">
          <th scope="col" class="py-2 pr-4 text-left font-medium">Name</th>
          <th scope="col" class="py-2 pr-4 text-left font-medium">Qty</th>
          <th scope="col" class="py-2 pr-4 text-left font-medium">SKU</th>
          <th scope="col" class="py-2 text-left font-medium">Supplier</th>
        </tr>
      </thead>
      <tbody>
        {models.map(m => (
          <tr class="border-b border-border">
            <td class="py-1 pr-4">{m.name}</td>
            <td class="py-1 pr-4">{m.qty}</td>
            <td class="py-1 pr-4">{m.sku ?? ''}</td>
            <td class="py-1">
              {m.supplier
                ? <a href={`/supplier/${slugifyStr(m.supplier)}/`} class="text-accent hover:underline">{m.supplier}</a>
                : ''}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
